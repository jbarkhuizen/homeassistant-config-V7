{# =============================================================================
SYSTEM OVERVIEW NOTIFICATION MACROS
File: /config/templates/system_overview_notifications.jinja
Purpose: Provide centralized macros for System Overview (Email + Telegram)
Updated: {{ now().strftime('%Y-%m-%d %H:%M:%S') }}
============================================================================= #}

{# ------------------------------- HELPERS ---------------------------------- #}
{%- macro _fmt(v, default='unknown') -%}
  {{ (v if v not in [None, 'unknown', 'unavailable', 'None', ''] else default) }}
{%- endmacro -%}

{%- macro _pct_str(v) -%}
  {%- set x = (v | float(0)) -%}
  {{ '{:.1f}%'.format(x) }}
{%- endmacro -%}

{%- macro _mb_str(v) -%}
  {%- set x = (v | float(0)) -%}
  {{ '{:.2f} MB'.format(x) }}
{%- endmacro -%}

{%- macro _num(v, prec=2, default='0') -%}
  {%- set x = (v | float(default)) -%}
  {{ ('{0:.' ~ prec ~ 'f}').format(x) }}
{%- endmacro -%}

{%- macro _kwh(v) -%}{{ _num(v, 2, 0) }} kWh{%- endmacro -%}
{%- macro _pct(v) -%}{{ _num(v, 1, 0) }}%{%- endmacro -%}

{%- macro _safe_sub(a, b) -%}
  {%- set a1 = (a | float(0)) -%}
  {%- set b1 = (b | float(0)) -%}
  {{ (a1 - b1) }}
{%- endmacro -%}

{%- macro _safe_ratio(n, d, prec=1) -%}
  {%- set n1 = (n | float(0)) -%}
  {%- set d1 = (d | float(0)) -%}
  {%- if d1 > 0 -%}
    {{ _num(100.0 * n1 / d1, prec, 0) }}
  {%- else -%}
    N/A
  {%- endif -%}
{%- endmacro -%}

{# ------------------------------ DATA GATHERING ----------------------------- #}
{%- set ts = now().strftime('%Y-%m-%d %H:%M:%S') %}

{# System Health #}
{%- set cpu_use = states('sensor.system_monitor_processor_use') %}
{%- set cpu_temp = states('sensor.system_monitor_processor_temperature') %}
{%- set mem_use_pct = states('sensor.system_monitor_memory_usage') %}
{%- set disk_used = states('sensor.home_assistant_host_disk_used') %}
{%- set disk_total = states('sensor.home_assistant_host_disk_total') %}
{%- set disk_free = states('sensor.home_assistant_host_disk_free') %}
{%- set health_score = states('sensor.system_health_score') %}

{# Database / Logs #}
{%- set db_size = states('sensor.homeassistant_db_size_mb') %}
{%- set log_size = states('sensor.home_assistant_log_size') %}

{# Updates #}
{%- set updates_total = state_attr('sensor.home_assistant_updates_summary', 'total_updates') | default(0) %}
{%- set updates_friendly = state_attr('sensor.home_assistant_updates_summary', 'friendly_summary') | default('No summary available') %}
{%- set updates_binary = states('binary_sensor.updates_available') %}

{# Add-on health (Running) #}
{%- set addons = [
  ('Node-RED','binary_sensor.node_red_running'),
  ('Grafana','binary_sensor.grafana_running'),
  ('Mosquitto','binary_sensor.mosquitto_broker_running'),
  ('InfluxDB','binary_sensor.influxdb_running'),
  ('AdGuard Home','binary_sensor.adguard_home_running'),
  ('Studio Code Server','binary_sensor.studio_code_server_running'),
  ('Samba Share','binary_sensor.samba_share_running'),
  ('Matter Server','binary_sensor.matter_server_running')
] %}
{%- set ns = namespace(down=[]) %}
{%- for name, ent in addons %}
  {%- if states(ent) not in ['on', 'True'] %}
    {%- set ns.down = ns.down + [name] %}
  {%- endif %}
{%- endfor %}
{%- set addons_down = ns.down %}

{# Backups #}
{%- set backup_state = states('sensor.backup_backup_manager_state') %}
{%- set backup_last_success = states('sensor.backup_last_successful_automatic_backup') %}
{%- set backup_last_attempt = states('sensor.backup_last_attempted_automatic_backup') %}
{%- set backup_next = states('sensor.backup_next_scheduled_automatic_backup') %}

{# Network / Connectivity #}
{%- set remote_ui = states('binary_sensor.remote_ui') %}
{%- set router_ping = states('binary_sensor.192_168_1_1') %}
{%- set node_http = states('sensor.node_red_http_status_code') %}
{%- set graf_http = states('sensor.grafana_http_status_code') %}

{# Security #}
{%- set badlogin = states('sensor.badlogin') %}
{%- set ipbans = states('sensor.home_assistant_ip_bans_count') %}

{# Solar / Inverter (instant + today) #}
{%- set soc_combined = states('sensor.deyeinvertercombined_battery_soc') %}
{%- set pv_today = states('sensor.deyeinvertercombined_summary_day_pv') %}
{%- set load_today = states('sensor.deyeinvertercombined_summary_day_load') %}
{%- set grid_buy_today = states('sensor.deyeinvertercombined_summary_day_grid_import_buy') %}
{%- set grid_sell_today = states('sensor.deyeinvertercombined_summary_day_grid_export_sell') %}
{%- set pv_power_now = states('sensor.deyeinvertercombined_pv_power') %}
{%- set grid_power_now = states('sensor.deyeinvertercombined_grid_power_ct_clamp') %}
{%- set batt_soc = states('sensor.deyeinvertercombined_battery_soc') %}

{# Weekly Solar metrics (7d vs prior 7d) — used only on Mondays #}
{%- set pv_7  = states('sensor.solar_pv_energy_change_7d') %}
{%- set pv_14 = states('sensor.solar_pv_energy_change_14d') %}
{%- set load_7  = states('sensor.solar_load_energy_change_7d') %}
{%- set load_14 = states('sensor.solar_load_energy_change_14d') %}
{%- set imp_7  = states('sensor.solar_grid_import_energy_change_7d') %}
{%- set imp_14 = states('sensor.solar_grid_import_energy_change_14d') %}
{%- set exp_7  = states('sensor.solar_grid_export_energy_change_7d') %}
{%- set exp_14 = states('sensor.solar_grid_export_energy_change_14d') %}

{%- set pv_prev   = [(_safe_sub(pv_14, pv_7) | float(0)), 0] | max %}
{%- set load_prev = [(_safe_sub(load_14, load_7) | float(0)), 0] | max %}
{%- set imp_prev  = [(_safe_sub(imp_14, imp_7) | float(0)), 0] | max %}
{%- set exp_prev  = [(_safe_sub(exp_14, exp_7) | float(0)), 0] | max %}

{%- set self_7   = (pv_7 | float(0)) - (exp_7 | float(0)) %}
{%- set self_prev = (pv_prev | float(0)) - (exp_prev | float(0)) %}
{%- set self_pct_7   = _safe_ratio(self_7, pv_7, 1) %}
{%- set self_pct_prev = _safe_ratio(self_prev, pv_prev, 1) %}
{%- set grid_dep_7   = _safe_ratio(imp_7, load_7, 1) %}
{%- set grid_dep_prev = _safe_ratio(imp_prev, load_prev, 1) %}

{%- set verdict = (
  'Load down' if ((load_7 | float(0)) < (load_prev | float(0))) else
  'Grid dependency down' if ((grid_dep_7 is string) and (grid_dep_prev is string) and (grid_dep_7.replace('%','') | float(0) < grid_dep_prev.replace('%','') | float(0))) else
  'PV up' if ((pv_7 | float(0)) > (pv_prev | float(0))) else
  'Stable'
) %}

